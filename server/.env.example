# ─────────────────────────────────────────────────────────────────────────────
# Cyventura CTF Platform – Environment Configuration
# Copy this file to .env and fill in real values before running the server.
# ─────────────────────────────────────────────────────────────────────────────

# ── App ───────────────────────────────────────────────────────────────────────
APP_NAME="Cyventura CTF Platform"
APP_VERSION="2.0.0"
DEBUG=false

# ── MongoDB ───────────────────────────────────────────────────────────────────
# Local: mongodb://localhost:27017
# Atlas: mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority
MONGODB_URI=mongodb://localhost:27017
DATABASE_NAME=cyventura_ctf

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate a strong secret: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=CHANGE_ME_use_a_strong_random_secret_key_here
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440   # 24 hours

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins
ALLOWED_ORIGINS=["http://localhost:5173","http://localhost:3000"]
